# ==============================================================================
# ПАРАМЕТРЫ БАЗЫ ДАННЫХ (PostgreSQL)
# ==============================================================================
DB_USER=postgres
DB_PASSWORD=postgres123
DB_NAME=taekwondo_db
DB_PORT=5432

# ==============================================================================
# ПАРАМЕТРЫ PGADMIN (Веб-интерфейс)
# ==============================================================================
# Доступ будет по адресу http://localhost:5050
PGADMIN_EMAIL=admin@taekwondo.ru
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# ==============================================================================
# СИСТЕМНЫЕ НАСТРОЙКИ
# ==============================================================================
# Часовой пояс для логов и времени взвешиваний
TZ=Europe/Moscow
